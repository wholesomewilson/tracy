# Copy to .env and adjust. Never commit .env.

# Secrets
FINNHUB_API_KEY=
# false = read finnhub_earnings.json at project root; true = live Finnhub API (requires key)
FINNHUB_EARNINGS_USE_API=false

# Screening criteria
EARNINGS_ALLOWED_EXCHANGES=NMS,NYQ
EARNINGS_MIN_MARKET_CAP=10000000000
EARNINGS_MAX_DEBT_TO_EQUITY=1.5
EARNINGS_MIN_CURRENT_RATIO=1.1
EARNINGS_MIN_ROE=0.15
EARNINGS_MIN_INSTITUTIONAL_OWNERSHIP=0.30

# Options filters (ranking only)
OPTIONS_MIN_DELTA=-0.99

# General
RISK_FREE_RATE=0.037
CORS_ORIGINS=http://localhost:3000
